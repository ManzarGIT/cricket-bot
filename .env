# ============================================================
# WhatsApp Cricket Bot — Environment Variables
# ============================================================
# Copy this file, rename it to .env, and fill in your values.
# NEVER share your .env file or push it to GitHub.
# ============================================================

# --- WhatsApp Cloud API ---
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_
WHATSAPP_PHONE_NUMBER_ID=1004951639366147

# --- Webhook Verification ---
# Make up any random word/phrase you want (example: cricketbot2024)
# You will use this SAME value when registering your webhook on Meta
WEBHOOK_VERIFY_TOKEN=manzar@cricketbot2026

# --- Cricket API ---
# Get from: https://cricapi.com → Sign up → Dashboard → API Key
CRICKET_API_KEY=3e0bd39d-dc56-4ed3-9de2-058614e20810

# --- Server ---
# The port your server runs on (3000 is standard, leave it)
PORT=3000
